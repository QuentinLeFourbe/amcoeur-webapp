# Backoffice Environment Variables

# Microsoft Client ID for PKCE Authentication
# Must match the one used in the server
VITE_MS_CLIENT_ID=your-microsoft-client-id-here

# Google OAuth (Optional/Migration)
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
VITE_GOOGLE_CLIENT_NOT_SO_SECRET=your-google-client-secret-here
