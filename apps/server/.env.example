# Server Environment Variables
NODE_ENV=development

# Database Configuration
# Default values for local Docker development
DB_URI=mongodb://localhost:27017/amcoeur
REDIS_URL=redis://localhost:6379

# Authentication (Microsoft PKCE)
# You will need to create an Azure app registration to get these
MS_CLIENT_ID=your-microsoft-client-id-here
ADMIN_MS_ID=your-microsoft-user-id-here

# Security
# Google ReCaptcha v2 server key
CAPTCHA_SERVER_KEY=your-captcha-secret-here

# Email Configuration
CONTACT_EMAIL=contact@example.com
ADMIN_EMAIL=admin@example.com
NOREPLY_EMAIL=noreply@example.com
NOREPLY_EMAIL_PASSWORD=your-email-password-here
