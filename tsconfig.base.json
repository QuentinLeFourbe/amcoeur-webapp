{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@amcoeur/types": ["libs/types/src/index.ts"],
      "@amcoeur/email-builder": ["libs/email-builder/src/index.ts"]
    },
    "module": "esnext",
    "moduleResolution": "node",
    "target": "esnext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["node_modules"]
}
