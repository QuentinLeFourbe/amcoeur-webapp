{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@amcoeur/types": ["libs/types/src/index.ts"]
    },
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "target": "esnext"
  }
}
